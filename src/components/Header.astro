---
import { Image } from "astro:assets";
import Link from "./Link.astro";
---

<header class="flex flex-row justify-center space-x-4">
  <nav
    class="bg-mocha-dark border-sky-blue hover:border-light-blue flex h-12 w-fit flex-row items-center justify-center rounded-lg border-2"
  >
    <Link href="/" title="Did you get it?">Terminal</Link>
    <Link href="/projects">Projects</Link>
    <Link href="/resume.pdf">Resume</Link>
    <Link href="/sponsor" external>Sponsor</Link>
  </nav>
  <nav
    class="bg-mocha-dark border-sky-blue hover:border-light-blue flex h-12 w-fit flex-row items-center justify-center rounded-lg border-2"
  >
    <Link href="/github" class="mx-2 opacity-100 hover:opacity-75" external
      ><Image
        width={36}
        height={36}
        loading={"eager"}
        alt="Github white logo"
        src="/icons/github.svg"
      />
    </Link>
    <Link href="/twitter" class="mx-2 opacity-100 hover:opacity-75" external
      ><Image
        width={36}
        height={36}
        loading={"eager"}
        alt="Twitter white logo"
        src="/icons/twitter.svg"
      />
    </Link>
    <Link href="/bluesky" class="mx-2 opacity-100 hover:opacity-75" external
      ><Image
        width={36}
        height={36}
        loading={"eager"}
        alt="Updated Bluesky logo, published February 2024."
        src="/icons/bluesky.svg"
      />
    </Link>
    <Link href="/discord" class="mx-2 opacity-100 hover:opacity-75" external
      ><Image
        width={36}
        height={36}
        loading={"eager"}
        alt="Discord logo"
        src="/icons/discord.svg"
      />
    </Link>
    <Link href="/linkedin" class="mx-2 opacity-100 hover:opacity-75" external
      ><Image
        width={36}
        height={36}
        loading={"eager"}
        alt="Linkedin logo"
        src="/icons/linkedin.svg"
      />
    </Link>
  </nav>
</header>
